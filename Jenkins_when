 pipeline{
    
    agent none

    
    parameters{
        
        choice(name: 'Environment', choices: ['dev', 'qa', 'prod'], description: 'Select environment')
    }

    stages {
        stage('CHECKOUT') {

             agent { label 'slave1' }  
              
                 
                steps {
                      checkout ([ $class: 'GitSCM',
                            branches: [[name: '*/main']], 
                            extensions: [], 
                            userRemoteConfigs: [[
                                 
                                url: 'https://github.com/rakeshjsj/jenkins_pipeline.git'
                            ]]
                        ])      
                }
        }
         stage('WHEN CONDITION') {
            
                    agent { label 'slave2' }

                       when{
                         branch 'main'
                        }
                    } 
            
                    steps { 

                        echo "TESTING STAGE 1"
                
                    }
                }
    }
        stage('PARALLEL TEST'){
            
            parallel{
            
                stage('STAGE 1 TESTING') {
            
                    agent { label 'slave2' } 
            
                    steps { 

                        echo "TESTING STAGE 1"
                
                    }
                }
                stage('STAGE 2 TESTING') {

                     agent { label 'slave2' } 

                    when{
                        expression{
                            params.Environment == 'dev'
                        }
                    }
            
                   
            
                    steps { 
            
                        echo "TESTING STAGE 2"
                    
                    }
                }
            }
         }
        stage('FINAL') {

             agent { label 'slave1' }  
                 
            steps {
                 
                   echo "FINISHED"
                          
            }
        }
    }
}
 